# Copy to .env and fill in. Database is required for auth; others optional for now.

# Required for auth and running the app
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/itinerary_db
JWT_SECRET=change-me-use-a-long-random-string

# Optional (API clients use mocks if missing)
# TICKETMASTER_API_KEY=
# YELP_API_KEY=
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# MAPBOX_ACCESS_TOKEN=
# GOOGLE_GEMINI_API_KEY=
