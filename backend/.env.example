# Async driver required at runtime; plain postgresql:// (e.g. Railway) is auto-upgraded in app/config.py.
DATABASE_URL=postgresql+asyncpg://USER@localhost:5432/itinerary_db
JWT_SECRET=

# Hosted UI origins, comma-separated (e.g. https://your-app.vercel.app)
CORS_ORIGINS=

DEMO_MODE=false

GOOGLE_GEMINI_API_KEY=
# Optional: Mapbox Directions + geocoding. If empty, routing uses free OSRM; geocoding uses Nominatim (see geocode.py).
MAPBOX_ACCESS_TOKEN=
TICKETMASTER_API_KEY=
YELP_API_KEY=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
