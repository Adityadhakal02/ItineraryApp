# Map: OpenStreetMap tiles via Leaflet (no browser map API key).

# Production: full API base URL, no trailing slash (e.g. https://your-api.railway.app).
# Local dev: leave empty to use Next rewrites → DEV_API_PROXY (default http://127.0.0.1:8000).
NEXT_PUBLIC_API_URL=

# Optional: override local API proxy target (next dev only).
# DEV_API_PROXY=http://127.0.0.1:8000
